<RadzenDataGrid Data="Items" TItem="DocumentRequestDto" AllowPaging="true" PageSize="10" AllowSorting="true" EmptyText="No document requests yet." class="data-card">
 <Columns><RadzenDataGridColumn TItem="DocumentRequestDto" Property="TrackingNumber" Title="Tracking #" /><RadzenDataGridColumn TItem="DocumentRequestDto" Property="Title" Title="Document" /><RadzenDataGridColumn TItem="DocumentRequestDto" Property="DocumentType" Title="Type" /><RadzenDataGridColumn TItem="DocumentRequestDto" Property="Status" Title="Status"><Template Context="x"><span class="status @x.Status.ToString().ToLower()">@x.Status</span></Template></RadzenDataGridColumn><RadzenDataGridColumn TItem="DocumentRequestDto" Property="CreatedAtUtc" Title="Submitted" FormatString="{0:dd MMM yyyy}" /><RadzenDataGridColumn TItem="DocumentRequestDto" Title=""><Template Context="x"><RadzenButton Text="View" Icon="visibility" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => Nav.NavigateTo($"requests/{x.Id}"))" /></Template></RadzenDataGridColumn></Columns>
</RadzenDataGrid>
@inject NavigationManager Nav
@code { [Parameter] public IEnumerable<DocumentRequestDto> Items { get; set; } = []; }
