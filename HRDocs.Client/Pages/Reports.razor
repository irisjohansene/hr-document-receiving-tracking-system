@page "/reports"
@attribute [Authorize(Roles="Admin")]
@inject ApiClient Api
@inject IJSRuntime JS
<PageTitle>Reports</PageTitle><div class="page-heading"><div><h1>Receiving reports</h1><p>Filter activity and export the result for audit or management review.</p></div><RadzenButton Text="Export CSV" Icon="download" Click="Export" /></div><RadzenCard class="filter-card"><div class="filter-grid"><RadzenDatePicker @bind-Value="filter.From" Placeholder="From date" DateFormat="dd MMM yyyy" /><RadzenDatePicker @bind-Value="filter.To" Placeholder="To date" DateFormat="dd MMM yyyy" /><RadzenDropDown @bind-Value="filter.Status" Data="statuses" Placeholder="All statuses" AllowClear="true" /><RadzenDropDown @bind-Value="filter.DepartmentId" Data="departments" TextProperty="Name" ValueProperty="Id" Placeholder="All departments" AllowClear="true" /><RadzenDropDown @bind-Value="filter.DocumentTypeId" Data="types" TextProperty="Name" ValueProperty="Id" Placeholder="All types" AllowClear="true" /><RadzenButton Text="Apply filters" Icon="filter_alt" Click="Load" /></div></RadzenCard><RequestTable Items="items" />
@code { ReportFilter filter=new();List<DocumentRequestDto> items=[];List<LookupItem> departments=[];List<LookupItem> types=[];DocumentRequestStatus[] statuses=Enum.GetValues<DocumentRequestStatus>();protected override async Task OnInitializedAsync(){departments=await Api.GetAsync<List<LookupItem>>("api/lookups/departments")??[];types=await Api.GetAsync<List<LookupItem>>("api/lookups/document-types")??[];await Load();}string Query()=>string.Join('&',new[]{filter.From is null?null:$"from={filter.From:O}",filter.To is null?null:$"to={filter.To:O}",filter.Status is null?null:$"status={filter.Status}",filter.DepartmentId is null?null:$"departmentId={filter.DepartmentId}",filter.DocumentTypeId is null?null:$"documentTypeId={filter.DocumentTypeId}"}.Where(x=>x is not null));async Task Load()=>items=await Api.GetAsync<List<DocumentRequestDto>>($"api/admin/reports?{Query()}")??[];async Task Export()=>await JS.InvokeVoidAsync("authDownload",$"api/admin/reports/csv?{Query()}",await Api.TokenAsync(),"hrdocs-report.csv"); }
