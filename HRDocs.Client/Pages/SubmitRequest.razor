@page "/submit"
@attribute [Authorize(Roles="User")]
@inject ApiClient Api
@inject NotificationService Toast
@inject NavigationManager Nav
@inject IJSRuntime JS
<PageTitle>New Request</PageTitle><div class="page-heading"><div><h1>Submit a receiving request</h1><p>Provide the routing details, attachment, and your electronic signature.</p></div></div>
<RadzenCard class="form-card"><RadzenTemplateForm TItem="CreateDocumentRequest" Data="model" Submit="@Submit"><div class="form-grid"><RadzenFormField Text="Document title"><RadzenTextBox @bind-Value="model.Title" Name="Title" Style="width:100%" /></RadzenFormField><RadzenFormField Text="Document type"><RadzenDropDown @bind-Value="model.DocumentTypeId" Data="types" TextProperty="Name" ValueProperty="Id" Style="width:100%" /></RadzenFormField><RadzenFormField Text="Sender department"><RadzenDropDown @bind-Value="model.SenderDepartmentId" Data="departments" TextProperty="Name" ValueProperty="Id" Style="width:100%" /></RadzenFormField><RadzenFormField Text="Recipient department"><RadzenDropDown @bind-Value="model.RecipientDepartmentId" Data="departments" TextProperty="Name" ValueProperty="Id" Style="width:100%" /></RadzenFormField></div><RadzenFormField Text="Description"><RadzenTextArea @bind-Value="model.Description" Rows="4" Style="width:100%" /></RadzenFormField><div class="upload-box"><InputFile OnChange="FileSelected" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" /><small>PDF, Word, JPG or PNG; maximum 10 MB.</small></div><div class="signature-block"><label>Electronic signature</label><canvas id="clientSignature" class="signature-pad" width="650" height="160"></canvas><RadzenButton Text="Clear signature" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => JS.InvokeVoidAsync("signaturePad.clear", "clientSignature"))" /></div><RadzenButton Text="Submit request" Icon="send" ButtonType="ButtonType.Submit" Disabled="busy" /></RadzenTemplateForm></RadzenCard>
@code { CreateDocumentRequest model=new(); List<LookupItem> departments=[];List<LookupItem> types=[];IBrowserFile? file;bool busy; protected override async Task OnInitializedAsync(){departments=await Api.GetAsync<List<LookupItem>>("api/lookups/departments")??[];types=await Api.GetAsync<List<LookupItem>>("api/lookups/document-types")??[];} protected override async Task OnAfterRenderAsync(bool first){if(first)await JS.InvokeVoidAsync("signaturePad.init","clientSignature");} void FileSelected(InputFileChangeEventArgs e)=>file=e.File; async Task Submit(CreateDocumentRequest _){try{busy=true;model.ClientSignatureDataUrl=await JS.InvokeAsync<string>("signaturePad.data","clientSignature");var form=new MultipartFormDataContent();form.Add(new StringContent(System.Text.Json.JsonSerializer.Serialize(model)),"data");if(file is not null){var stream=new StreamContent(file.OpenReadStream(10_000_000));stream.Headers.ContentType=new(file.ContentType);form.Add(stream,"attachment",file.Name);}using var r=await Api.SendAsync(HttpMethod.Post,"api/requests",form);if(!r.IsSuccessStatusCode)throw new InvalidOperationException(await r.Content.ReadAsStringAsync());Toast.Notify(NotificationSeverity.Success,"Submitted","Your receiving request is now pending.");Nav.NavigateTo("requests");}catch(Exception e){Toast.Notify(NotificationSeverity.Error,"Could not submit",e.Message);}finally{busy=false;}} }
