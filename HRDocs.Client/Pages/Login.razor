@page "/login"
@layout AuthLayout
@inject ApiClient Api
@inject TokenStore Store
@inject AuthenticationStateProvider Auth
@inject NavigationManager Nav
@inject NotificationService Toast

<PageTitle>Sign in</PageTitle>
<div class="auth-card">
    <div class="auth-logo">HR</div>
    <h1>Welcome back</h1>
    <p>Sign in to receive and track HR documents.</p>
    <div class="native-field">
        <label for="login-email">Email</label>
        <input id="login-email" class="rz-textbox" type="email" @bind="email" @bind:event="oninput" autocomplete="email" />
    </div>
    <div class="native-field">
        <label for="login-password">Password</label>
        <input id="login-password" class="rz-textbox" type="password" @bind="password" @bind:event="oninput" autocomplete="current-password" />
    </div>
    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="validation-message" style="margin-bottom:12px">@error</div>
    }
    <RadzenButton Text="Sign in" Icon="login" ButtonType="ButtonType.Button" Click="SubmitLogin" Disabled="busy" Style="width:100%" />
    <div class="auth-link">No account? <a href="register">Create one</a></div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? error;
    private bool busy;

    private async Task SubmitLogin()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            error = "Email and password are required.";
            return;
        }

        try
        {
            busy = true;
            var response = await Api.PostAsync<AuthResponse>("api/auth/login", new LoginRequest { Email = email, Password = password });
            if (response is null) return;
            await Store.SetAsync(response.Token);
            ((JwtAuthenticationStateProvider)Auth).Changed();
            Nav.NavigateTo(response.User.Role == AppRoles.Admin ? "admin" : "");
        }
        catch (Exception ex)
        {
            error = ex.Message;
            Toast.Notify(NotificationSeverity.Error, "Sign in failed", ex.Message);
        }
        finally { busy = false; }
    }
}
