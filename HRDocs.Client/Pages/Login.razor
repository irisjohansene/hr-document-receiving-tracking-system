@page "/login"
@layout AuthLayout
@inject ApiClient Api
@inject TokenStore Store
@inject AuthenticationStateProvider Auth
@inject NavigationManager Nav
@inject NotificationService Toast

<PageTitle>Sign in</PageTitle>
<div class="auth-card">
    <div class="auth-logo">HR</div>
    <h1>Welcome back</h1>
    <p>Sign in to receive and track HR documents.</p>
    <EditForm Model="model" OnValidSubmit="SubmitLogin" FormName="login">
        <DataAnnotationsValidator />
        <div class="native-field">
            <label for="login-email">Email</label>
            <InputText id="login-email" class="rz-textbox" @bind-Value="model.Email" autocomplete="email" />
            <ValidationMessage For="@(() => model.Email)" />
        </div>
        <div class="native-field">
            <label for="login-password">Password</label>
            <InputText id="login-password" class="rz-textbox" type="password" @bind-Value="model.Password" autocomplete="current-password" />
            <ValidationMessage For="@(() => model.Password)" />
        </div>
        <RadzenButton Text="Sign in" Icon="login" ButtonType="ButtonType.Submit" Disabled="busy" Style="width:100%" />
        <div class="auth-link">No account? <a href="register">Create one</a></div>
    </EditForm>
</div>

@code {
    private readonly LoginRequest model = new();
    private bool busy;

    private async Task SubmitLogin()
    {
        try
        {
            busy = true;
            var response = await Api.PostAsync<AuthResponse>("api/auth/login", model);
            if (response is null) return;
            await Store.SetAsync(response.Token);
            ((JwtAuthenticationStateProvider)Auth).Changed();
            Nav.NavigateTo(response.User.Role == AppRoles.Admin ? "admin" : "");
        }
        catch (Exception ex)
        {
            Toast.Notify(NotificationSeverity.Error, "Sign in failed", ex.Message);
        }
        finally { busy = false; }
    }
}
