@page "/requests/{Id:int}"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav
@inject NotificationService Toast
@inject IJSRuntime JS
<PageTitle>Request details</PageTitle>@if(item is null){<RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />}else{<div class="page-heading"><div><h1>@item.Title</h1><p>@item.TrackingNumber · <span class="status @item.Status.ToString().ToLower()">@item.Status</span></p></div>@if(item.Status is DocumentRequestStatus.Approved or DocumentRequestStatus.Completed){<RadzenButton Text="Download proof" Icon="picture_as_pdf" Click="DownloadProof" />}</div><div class="detail-grid"><RadzenCard><h3>Routing details</h3><dl><dt>Control number</dt><dd>@(item.ControlNumber??"Not assigned")</dd><dt>Document type</dt><dd>@item.DocumentType</dd><dt>From</dt><dd>@item.SenderDepartment</dd><dt>To</dt><dd>@item.RecipientDepartment</dd><dt>Submitted by</dt><dd>@item.SubmittedBy</dd><dt>Description</dt><dd>@item.Description</dd><dt>HR remarks</dt><dd>@(item.AdminRemarks??"—")</dd></dl>@foreach(var a in item.Attachments){<a class="attachment" href="@($"{ApiUrl}api/requests/{Id}/attachment/{a.Id}")" target="_blank"><RadzenIcon Icon="attach_file" />@a.OriginalFileName</a>}</RadzenCard><RadzenCard><h3>Status history</h3><div class="timeline">@foreach(var h in item.StatusHistory){<div><i></i><strong>@h.Status</strong><span>@h.ChangedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm") · @h.ChangedBy</span><p>@h.Remarks</p></div>}</div></RadzenCard></div><AuthorizeView Roles="Admin"><Authorized><RadzenCard class="review-card"><h3>HR review</h3><div class="form-grid"><RadzenFormField Text="Decision"><RadzenDropDown @bind-Value="review.Status" Data="reviewStatuses" Style="width:100%" /></RadzenFormField><RadzenFormField Text="Official control number"><RadzenTextBox @bind-Value="review.ControlNumber" Style="width:100%" /></RadzenFormField></div><RadzenFormField Text="HR remarks"><RadzenTextArea @bind-Value="review.AdminRemarks" Rows="3" Style="width:100%" /></RadzenFormField><label>HR electronic signature</label><canvas id="adminSignature" class="signature-pad" width="650" height="140"></canvas><RadzenButton Text="Save decision" Icon="verified" Click="SaveReview" /></RadzenCard></Authorized></AuthorizeView>}
@code { [Parameter]public int Id{get;set;} DocumentRequestDto? item;ReviewDocumentRequest review=new(){Status=DocumentRequestStatus.Approved};DocumentRequestStatus[] reviewStatuses=[DocumentRequestStatus.Approved,DocumentRequestStatus.Rejected,DocumentRequestStatus.Completed];string ApiUrl=>new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority)+"/";protected override async Task OnInitializedAsync(){item=await Api.GetAsync<DocumentRequestDto>($"api/requests/{Id}");if(item is not null){review.ControlNumber=item.ControlNumber;review.AdminRemarks=item.AdminRemarks;}}protected override async Task OnAfterRenderAsync(bool first){if(first)try{await JS.InvokeVoidAsync("signaturePad.init","adminSignature");}catch{}}async Task SaveReview(){try{review.AdminSignatureDataUrl=await JS.InvokeAsync<string>("signaturePad.data","adminSignature");await Api.PutAsync($"api/requests/{Id}/review",review);Toast.Notify(NotificationSeverity.Success,"Updated","The requester was notified.");item=await Api.GetAsync<DocumentRequestDto>($"api/requests/{Id}");}catch(Exception e){Toast.Notify(NotificationSeverity.Error,"Review failed",e.Message);}}async Task DownloadProof()=>await JS.InvokeVoidAsync("authDownload",$"api/requests/{Id}/proof",await Api.TokenAsync(),$"Receiving-{item!.TrackingNumber}.pdf"); }
