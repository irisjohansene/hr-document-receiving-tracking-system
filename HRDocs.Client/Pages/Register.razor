@page "/register"
@layout AuthLayout
@inject ApiClient Api
@inject TokenStore Store
@inject AuthenticationStateProvider Auth
@inject NavigationManager Nav
@inject NotificationService Toast
<PageTitle>Create account</PageTitle><div class="auth-card wide"><div class="auth-logo">HR</div><h1>Create your account</h1><p>Register to submit and track documents.</p><RadzenTemplateForm TItem="RegisterRequest" Data="model" Submit="@SubmitRegistration"><RadzenFormField Text="Full name"><RadzenTextBox @bind-Value="model.FullName" Name="Name" Style="width:100%" /></RadzenFormField><RadzenRequiredValidator Component="Name" Text="Name is required" /><RadzenFormField Text="Email"><RadzenTextBox @bind-Value="model.Email" Name="Email" Style="width:100%" /></RadzenFormField><RadzenRequiredValidator Component="Email" Text="Email is required" /><RadzenFormField Text="Department"><RadzenDropDown @bind-Value="model.DepartmentId" Data="departments" TextProperty="Name" ValueProperty="Id" Name="Dept" Style="width:100%" /></RadzenFormField><RadzenRequiredValidator Component="Dept" Text="Department is required" /><RadzenFormField Text="Password (8+ characters)"><RadzenPassword @bind-Value="model.Password" Name="Password" Style="width:100%" /></RadzenFormField><RadzenButton Text="Create account" ButtonType="ButtonType.Submit" Icon="person_add" Style="width:100%" /><div class="auth-link">Already registered? <a href="login">Sign in</a></div></RadzenTemplateForm></div>
@code { RegisterRequest model=new(); List<LookupItem> departments=[]; protected override async Task OnInitializedAsync()=>departments=await Api.GetAsync<List<LookupItem>>("api/lookups/departments")??[]; async Task SubmitRegistration(RegisterRequest _){try{var r=await Api.PostAsync<AuthResponse>("api/auth/register",model);if(r is null)return;await Store.SetAsync(r.Token);((JwtAuthenticationStateProvider)Auth).Changed();Nav.NavigateTo("");}catch(Exception e){Toast.Notify(NotificationSeverity.Error,"Registration failed",e.Message);}} }
